# Database Configuration
# Options: "mysql" or "sqlite" (default: sqlite for local dev)
DB_CLIENT=sqlite

# For SQLite (local development - no setup needed)
DB_FILE=./dev.sqlite3

# For MySQL (production or remote database)
# DB_HOST=127.0.0.1
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=beauty_model
# DB_PORT=3306

# Optional Google OAuth credentials for real Google sign-in
# Get these from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4173/api/auth/google/callback

# Node Environment
# NODE_ENV=development
